<Window x:Class="ConPtyTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ConPTY Terminal"
        Height="720"
        Width="1000"
        MinWidth="720"
        MinHeight="480">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="Command" />
            <TextBox x:Name="CommandTextBox"
                     Grid.Column="1"
                     Margin="0,0,8,0"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="cmd.exe /K chcp 65001 &gt; nul" />
            <Button x:Name="StartButton"
                    Grid.Column="2"
                    Width="90"
                    Margin="0,0,8,0"
                    Content="Start"
                    Click="StartButton_Click" />
            <Button x:Name="StopButton"
                    Grid.Column="3"
                    Width="90"
                    Margin="0,0,8,0"
                    Content="Stop"
                    Click="StopButton_Click"
                    IsEnabled="False" />
            <Button x:Name="RecoverButton"
                    Grid.Column="4"
                    Width="90"
                    Content="Recover"
                    Click="RecoverButton_Click"
                    IsEnabled="False" />
        </Grid>

        <TextBox x:Name="TerminalOutput"
                 Grid.Row="1"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="#111111"
                 Foreground="#E3E3E3"
                 BorderBrush="#303030"
                 Padding="8" />

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#666666"
                   Text="Ready" />

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox"
                     Grid.Column="0"
                     Height="30"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     FontFamily="Consolas"
                     KeyDown="InputTextBox_KeyDown" />
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Width="90"
                    Content="Send"
                    Click="SendButton_Click"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Window>
