<Window x:Class="ConPtyTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ConPTY Terminal"
        Width="1200"
        Height="760"
        MinWidth="840"
        MinHeight="520"
        Background="#0E0E0E"
        Foreground="#F3F3F3"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="ChromeBrush" Color="#151515" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="TabIdleBrush" Color="#1B1B1B" />
        <SolidColorBrush x:Key="TabActiveBrush" Color="#0E0E0E" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#232323" />
        <SolidColorBrush x:Key="TabTextBrush" Color="#EDEDED" />
        <SolidColorBrush x:Key="TabTextMutedBrush" Color="#A7A7A7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4BA3FF" />

        <Style x:Key="TabActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource TabTextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="TabTextButtonStyle" TargetType="Button" BasedOn="{StaticResource TabActionButtonStyle}">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ProfilePickerButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Foreground" Value="{StaticResource TabTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#232323" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#232323" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2B2B2B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource ChromeBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <ListBox x:Name="TabStrip"
                         DockPanel.Dock="Left"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="TabStrip_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <Button x:Name="NewTabButton"
                        DockPanel.Dock="Left"
                        Style="{StaticResource TabActionButtonStyle}"
                        FontSize="20"
                        Content="+"
                        Click="NewTabButton_Click" />
                <Button x:Name="SettingsButton"
                        DockPanel.Dock="Left"
                        Style="{StaticResource TabTextButtonStyle}"
                        Content="Settings"
                        Click="SettingsButton_Click" />
            </DockPanel>
        </Border>

        <Popup x:Name="ProfilePickerPopup"
               Grid.Row="0"
               PlacementTarget="{Binding ElementName=NewTabButton}"
               Placement="Bottom"
               HorizontalOffset="-8"
               VerticalOffset="4"
               AllowsTransparency="True"
               StaysOpen="False">
            <Border MinWidth="300"
                    Background="#151515"
                    BorderBrush="{StaticResource ChromeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="8">
                <StackPanel x:Name="ProfilePickerPanel" />
            </Border>
        </Popup>

        <ContentControl x:Name="ActiveTabHost"
                        Grid.Row="1"
                        Focusable="False"
                        Background="#0E0E0E" />
    </Grid>
</Window>
